# Ensure shell scripts always use LF line endings on all platforms
*.sh text eol=lf

# Python / JS / config — normalize to LF
*.py  text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.conf text eol=lf
*.md   text eol=lf
Dockerfile text eol=lf
